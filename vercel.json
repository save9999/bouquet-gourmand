{
  "version": 2,
  "builds": [
    { "src": "api/publish.js", "use": "@vercel/node" },
    { "src": "api/create-payment-intent.js", "use": "@vercel/node" },
    { "src": "api/webhook.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/publish", "dest": "/api/publish.js" },
    { "src": "/api/create-payment-intent", "dest": "/api/create-payment-intent.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/panier", "dest": "/panier.html" },
    { "src": "/merci", "dest": "/merci.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.jpg)", "dest": "/$1" },
    { "src": "/(.*\\.svg)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "cleanUrls": true
}
